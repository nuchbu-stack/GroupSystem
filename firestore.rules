rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserEmail() {
      return (request.auth != null && 'email' in request.auth.token) ? request.auth.token.email.lower() : '';
    }
    
    function isInstructor() {
      return isSignedIn() && (getUserEmail().matches('.*@bu.ac.th') || getUserEmail() == 'nuch.bu@gmail.com');
    }
    
    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /assignments/{assignmentId} {
      allow read: if isSignedIn() && (
        isInstructor() || 
        (resource.data.studentRoster != null && getUserEmail() in resource.data.studentRoster)
      );
      
      allow create: if isSignedIn() && isInstructor() && (
        request.resource.data.instructorEmail.lower() == getUserEmail()
      );
      
      allow update: if isSignedIn() && isInstructor() && (
        resource.data.instructorEmail.lower() == getUserEmail() &&
        request.resource.data.instructorEmail.lower() == resource.data.instructorEmail.lower()
      );
      
      allow delete: if isSignedIn() && isInstructor() && (
        resource.data.instructorEmail.lower() == getUserEmail()
      );
      
      match /groups/{groupId} {
        function getAssignment() {
          return get(/databases/$(database)/documents/assignments/$(assignmentId));
        }
        
        function isAssignmentInstructor() {
          return getAssignment().data.instructorEmail.lower() == getUserEmail();
        }
        
        function isAssignmentStudent() {
          return getAssignment().data.studentRoster != null && getUserEmail() in getAssignment().data.studentRoster;
        }
        
        allow read: if isSignedIn() && (
          isInstructor() || isAssignmentStudent()
        );
        
        allow create: if isSignedIn() && (
          isInstructor() || isAssignmentStudent()
        );
        
        allow update: if isSignedIn() && (
          isInstructor() || isAssignmentStudent()
        );
        
        allow delete: if isSignedIn() && (
          isAssignmentInstructor()
        );
      }
    }
  }
}
